# ── Dynatrace ──────────────────────────────────────────────────────────────────
# Your Dynatrace SaaS environment base URL (no trailing slash, no /api path)
DT_ENDPOINT=https://<your-environment-id>.live.dynatrace.com

# API token with scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest
DT_API_TOKEN=dt0c01.<your-token-value>

# PaaS token — required only if installing OneAgent manually on a host
# OneAgent 1.341+ cannot be installed inside a container; use host-level installation instead.
# Obtain from: Settings > Integration > Platform as a Service
DT_PAAS_TOKEN=dt0c01.<your-paas-token-value>

# ── LLM Provider ───────────────────────────────────────────────────────────────
# Supported providers: anthropic (default), openai
LLM_PROVIDER=anthropic

# Anthropic — required when LLM_PROVIDER=anthropic
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-<your-api-key>

# OpenAI — required when LLM_PROVIDER=openai
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-<your-openai-api-key>

# Model override — if unset, defaults to the provider's recommended evaluation model:
#   anthropic -> claude-haiku-4-5-20251001
#   openai    -> gpt-4o-mini
MODEL=

# ── Optional customization ─────────────────────────────────────────────────────
# Service name reported to Dynatrace AI Observability (OpenLLMetry + OpenInference)
SERVICE_NAME=dt-ai-obs-test

# Host group for the OneAgent container
HOST_GROUP=dt-ai-obs-test
