FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @dynatrace-oss/dynatrace-mcp-server \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements_openinference.txt .
RUN pip install --no-cache-dir -r requirements_openinference.txt

COPY app_openinference.py .
COPY llm_client.py .
COPY mcp_client.py .
COPY log_setup.py .

EXPOSE 8000

CMD ["uvicorn", "app_openinference:app", "--host", "0.0.0.0", "--port", "8000"]
