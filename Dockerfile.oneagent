FROM python:3.11-slim

# wget needed to download the OneAgent installer at container startup
# curl + Node.js 24 + dynatrace-mcp-server for MCP tool-use support
RUN apt-get update && apt-get install -y --no-install-recommends wget curl gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g @dynatrace-oss/dynatrace-mcp-server \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements_oneagent.txt .
RUN pip install --no-cache-dir -r requirements_oneagent.txt

COPY app_oneagent.py .
COPY llm_client.py .
COPY mcp_client.py .
COPY log_setup.py .
COPY docker-entrypoint-oneagent.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8000

# Entrypoint downloads + installs OneAgent, then starts uvicorn.
# Set DT_PAAS_TOKEN and DT_ENDPOINT in your .env to enable instrumentation.
ENTRYPOINT ["/entrypoint.sh"]
